<resources xmlns:tools="http://schemas.android.com/tools">
    <!--Splash theme-->
    <style name="Theme.ToolBarTopBarApp.Splash" parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@color/black_red</item>
        <!-- Background color -->

        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <!-- Splash icon -->

        <item name="windowSplashScreenAnimationDuration">1000</item>
        <!-- Animation duration -->

        <item name="postSplashScreenTheme">@style/Theme.ToolBarTopBarApp</item>
        <!-- Main theme after splash -->

    </style>
    <!-- Base application theme. -->
    <style name="Theme.ToolBarTopBarApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/lavender</item>
        <item name="colorPrimaryVariant">@color/lavender</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in</item>
        <item name="android:windowExitAnimation">@anim/slide_out</item>
    </style>

</resources>